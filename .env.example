# =============================================================================
# auto-stack-monitor — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA comite o .env no git — ele já está no .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_DB=zabbix
POSTGRES_USER=zabbix
POSTGRES_PASSWORD=Z@bbix_S3cur3_P@ss!   # TROQUE ISSO

# -----------------------------------------------------------------------------
# Zabbix
# -----------------------------------------------------------------------------
ZABBIX_VERSION=7.0-latest
ZBX_SERVER_NAME=Auto-Stack Monitor
ZBX_SERVER_PORT=10051
ZBX_FRONTEND_PORT=8080
ZBX_AGENT_PORT=10050
ZBX_STARTPOLLERS=5
ZBX_CACHESIZE=128M
ZBX_TIMEOUT=30

# Credenciais padrão da API Zabbix (usuário Admin criado na instalação)
ZBX_API_URL=http://zabbix-frontend:8080/api_jsonrpc.php
ZBX_API_USER=Admin
ZBX_API_PASSWORD=zabbix               # TROQUE APÓS PRIMEIRO LOGIN

# Nome do host Docker que o agent vai registrar
DOCKER_HOST_NAME=docker-host

# -----------------------------------------------------------------------------
# Grafana
# -----------------------------------------------------------------------------
GF_PORT=3000
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=admin     # TROQUE ISSO

# -----------------------------------------------------------------------------
# Telegram Bot
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=123456789:AABBCCDDEEFFaabbccddeeff-exemplo
TELEGRAM_CHAT_ID=-100123456789        # Grupo ou canal (negativo) / usuário (positivo)

# -----------------------------------------------------------------------------
# Timezone
# -----------------------------------------------------------------------------
TZ=America/Bahia

# -----------------------------------------------------------------------------
# Primeiro host a monitorar (opcional — setup.sh vai perguntar)
# -----------------------------------------------------------------------------
FIRST_HOST_IP=
FIRST_HOST_NAME=
